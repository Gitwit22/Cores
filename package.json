{
  "name": "@nxtlvl/cores",
  "version": "0.0.1",
  "private": true,
  "description": "Reusable internal core modules for Nxt Lvl applications",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:auth-core": "tsc --build packages/auth-core",
    "build:ticket-core": "tsc --build packages/ticket-core",
    "build:shared": "tsc --build packages/shared",
    "build:document-intelligence-core": "tsc --build packages/document-intelligence-core",
    "build:document-intelligence-service": "tsc --build packages/document-intelligence-service",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "clean": "find packages -name dist -type d -exec rm -rf {} + 2>/dev/null; find packages -name '*.tsbuildinfo' -delete 2>/dev/null; echo 'Clean complete'"
  },
  "dependencies": {
    "@types/node": "^22.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "5.5.4"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/packages"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/tsconfig.jest.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^@nxtlvl/shared(.*)$": "<rootDir>/packages/shared/src$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
